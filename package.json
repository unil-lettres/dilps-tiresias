{
    "name": "dilps-tiresias",
    "private": true,
    "license": "MIT",
    "scripts": {
        "ng": "ng",
        "postinstall": "playwright install chromium",
        "dev": "yarn codegen && yarn set-env && yarn clean-env && ng serve",
        "dev-docker": "yarn codegen && yarn set-env && yarn clean-env && ng build --configuration=development --watch --output-hashing=all",
        "prod": "yarn codegen && yarn set-env --configuration=production && yarn clean-env && ng build --configuration=production",
        "prod-map": "yarn codegen && yarn set-env --configuration=production && yarn clean-env && ng build --configuration=production,map --output-hashing=none",
        "staging": "yarn codegen && yarn set-env --configuration=staging && yarn clean-env && ng build --configuration=staging",
        "staging-map": "yarn codegen && yarn set-env --configuration=staging && yarn clean-env && ng build --configuration=staging,map --output-hashing=none",
        "test": "yarn codegen && ng test",
        "lint": "ng lint --max-warnings 0",
        "e2e": "playwright test",
        "codegen": "./bin/dump-schema && graphql-codegen --config codegen.ts",
        "set-env": "ts-node scripts/setenv.ts",
        "clean-env": "prettier --write client/environments/*",
        "report-build": "bugsnag-build-reporter -n 'Dilps/Tiresias Deployer'"
    },
    "dependencies": {
        "@angular/cdk": "^20.2.10",
        "@angular/common": "^20.3.14",
        "@angular/compiler": "^20.3.16",
        "@angular/core": "^20.3.16",
        "@angular/forms": "^20.3.7",
        "@angular/google-maps": "20.2.10",
        "@angular/localize": "^20.3.7",
        "@angular/material": "^20.2.10",
        "@angular/platform-browser": "^20.3.7",
        "@angular/router": "^20.3.7",
        "@apollo/client": "^3.13.7",
        "@bugsnag/core": "^8.4.0",
        "@bugsnag/js": "^8.4.0",
        "@bugsnag/plugin-angular": "^8.5.0",
        "@ecodev/angular-natural-gallery": "^24.0.0",
        "@ecodev/natural": "^65.0.5",
        "@ecodev/natural-layout": "^2.0.2",
        "@graphql-codegen/cli": "^6.0.0",
        "@graphql-codegen/typescript-apollo-angular": "^4.0.1",
        "@graphql-codegen/typescript-operations": "^5.0.0",
        "@graphql-tools/mock": "^9.0.25",
        "@types/googlemaps": "^3.43.3",
        "apollo-angular": "^11.0.0",
        "bugsnag-build-reporter": "^2.0.0",
        "dotenv": "^17.2.2",
        "es-toolkit": "^1.39.10",
        "graphql": "^16.11.0",
        "highcharts": "^12.4.0",
        "highcharts-angular": "^5.1.0",
        "ngx-progressbar": "^14.0.0",
        "ngx-quill": "^28.0.1",
        "ngx-scrollbar": "^18.0.0",
        "quill": "^2.0.3",
        "rxjs": "^7.8.2",
        "snazzy-info-window": "^1.1.1",
        "striptags": "^4.0.0-alpha.4",
        "swiper": "^11.2.10",
        "tslib": "^2.8.1",
        "type-fest": "^5.3.1",
        "yargs": "^18.0.0",
        "zone.js": "~0.15.1"
    },
    "devDependencies": {
        "@angular/build": "^20.3.7",
        "@angular/cli": "^20.3.7",
        "@angular/compiler-cli": "^20.3.7",
        "@playwright/test": "^1.55.0",
        "@types/jasmine": "~5.1.9",
        "@types/node": "^22.14.1",
        "angular-eslint": "^20.2.0",
        "eslint": "^9.24.0",
        "jasmine-core": "~5.10.0",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-cli": "^2.0.0",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "^2.1.0",
        "postcss": "^8.5.6",
        "prettier": "3.8.1",
        "prettier-plugin-css-order": "^2.1.2",
        "ts-node": "^10.9.2",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.29.1"
    }
}
